# Copy this file to .env and fill in values when you want external API integration.
APP_TIMEZONE=Asia/Seoul
DATABASE_PATH=data/personal_assistant.db

# Optional: Google Calendar API integration.
# For a service account, share the target calendar with the service account email.
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_FILE=

# Optional: LLM command parsing. Gemini is preferred for this assignment.
GEMINI_API_KEY=
OPENAI_API_KEY=

