# Copy this file to .env and fill in values when you want external API integration.
APP_TIMEZONE=Asia/Seoul
DATABASE_PATH=data/personal_assistant_pc.db

# Optional: Google Calendar API integration.
# For a service account, share the target calendar with the service account email.
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_OAUTH_CLIENT_SECRET_FILE=
GOOGLE_OAUTH_TOKEN_FILE=data/google_token.json
GOOGLE_REGISTERED_EMAIL=
# Optional OAuth note: if you use GOOGLE_OAUTH_CLIENT_SECRET_FILE,
# install a compatible google-auth-oauthlib version manually in .venv.

# Optional: LLM command parsing. Gemini is preferred for this assignment.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: interest site collection targets.
SITE_COLLECTION_INTERVAL_HOURS=3
SEOUL50PLUS_URL=https://www.50plus.or.kr/
SEOUL50PLUS_TRAINING_URL=https://www.50plus.or.kr/in_appList.do?bizSeUrl=IN49009&rcrtSeUrl=IN47002
SEOUL50PLUS_JOB_SUPPORT_URL=https://www.50plus.or.kr/in_appList.do?bizSeUrl=IN49001&rcrtSeUrl=IN47002
KSTARTUP_URL=https://www.k-startup.go.kr/web/contents/bizpbanc-ongoing.do
